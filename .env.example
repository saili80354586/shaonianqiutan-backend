# 服务端口
PORT=8080

# 数据库配置（当前本地/演示仍使用 SQLite）
DB_PATH=./shaonianqiutan.db

# JWT配置（生产必须改成强随机值）
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=168h

# 环境模式：本地 development，生产 production
NODE_ENV=development
GIN_MODE=debug

# 支付模式：mock 允许直接走模拟支付闭环；real 预留给未来真实支付接入。
# 非 development 环境必须显式配置，测试服务器如需保留模拟支付请继续设为 mock。
PAYMENT_MODE=mock

# 短信模式：mock 返回固定验证码 123456；接入真实短信服务后切到 real。
# 非 development 环境必须显式配置，测试服务器未接短信服务时请设为 mock。
SMS_MODE=mock

# 测试阶段允许分析师注册后直接进入工作台；正式审核流程恢复时设为 false。
# 非 development 环境必须显式配置，避免服务器漏配时误开测试注册策略。
ANALYST_REGISTRATION_AUTO_APPROVE=true

# 是否在分析师注册后自动创建并派发默认样例订单
ANALYST_DEFAULT_DEMO_ORDER_ENABLED=false

# 默认样例订单模板ID（启用上面开关时必须填写）
ANALYST_DEFAULT_DEMO_ORDER_TEMPLATE_ORDER_ID=

# 后端公开基础URL
BASE_URL=http://localhost:8080

# 前端URL（生产环境必填，用于 CORS 和 WebSocket Origin 白名单）
FRONTEND_URL=http://localhost:5173

# 允许的前端来源，逗号分隔；适合生产中同时存在 app/admin 等多个域名。
# 未设置时默认使用 FRONTEND_URL。
# 开发环境只会额外允许这些精确来源：localhost:5173、127.0.0.1:5173、localhost:3000。
CORS_ALLOWED_ORIGINS=

# 对象存储配置。开发环境可使用 local；生产环境使用 cos。
STORAGE_DRIVER=local
COS_BUCKET=
COS_REGION=ap-shanghai
COS_BUCKET_URL=
COS_OBJECT_PREFIX=prod
COS_SECRET_ID=
COS_SECRET_KEY=
COS_UPLOAD_EXPIRE_SECONDS=900
COS_DOWNLOAD_EXPIRE_SECONDS=1800
ORDER_SOURCE_VIDEO_DELETE_AFTER_DELIVERED_SECONDS=604800
ORDER_CANCELLED_DELETE_AFTER_SECONDS=86400

# 视频分析报告生成（OpenAI 兼容接口；未配置密钥时相关功能会返回配置错误）
# AI_MODEL 可在 gpt-5.5 和 deepseek-v4-pro 间切换，默认优先使用 gpt-5.5。
AI_API_KEY=
AI_BASE_URL=https://api.anhepro.com/v1
AI_MODEL=gpt-5.5

# 一次性模板订单创建工具参数（仅在需要生成样例订单时使用）
DEMO_PLAYER_PHONE=
DEMO_PLAYER_NAME=
DEMO_MATCH_NAME=
DEMO_PLAYER_POSITION=
DEMO_JERSEY_COLOR=
DEMO_JERSEY_NUMBER=
DEMO_VIDEO_URL=
DEMO_VIDEO_SOURCE_FILE=
DEMO_VIDEO_FILENAME=
DEMO_ORDER_TYPE=pro
DEMO_ORDER_AMOUNT=0
DEMO_VIDEO_DURATION=0
DEMO_ORDER_REMARK=系统样例模板订单
