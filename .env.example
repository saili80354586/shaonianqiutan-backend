# 服务端口
PORT=8080

# 数据库配置（当前本地/演示仍使用 SQLite）
DB_PATH=./shaonianqiutan.db

# JWT配置（生产必须改成强随机值）
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=168h

# 环境模式：本地 development，生产 production
NODE_ENV=development
GIN_MODE=debug

# 后端公开基础URL
BASE_URL=http://localhost:8080

# 前端URL（生产环境必填，用于 CORS 和 WebSocket Origin 白名单）
FRONTEND_URL=http://localhost:5173

# AI 报告生成（可选；未配置时相关功能会返回配置错误）
AI_API_KEY=
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
AI_MODEL=glm-4-flash
